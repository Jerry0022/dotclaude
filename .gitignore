# Dependencies
scripts/node_modules/
scripts/package-lock.json

# Runtime data (generated at startup)
scripts/config.json
scripts/session-history.json
scripts/usage-live.json
scripts/dotclaude-repo-path
scripts/dotclaude-plan
scripts/diagrams/index.html

# Credentials
.credentials.json

# Cache
cache/

# Channel credentials and state
channels/

# Plugin runtime data
plugins/cache/
plugins/data/
plugins/.install-manifests/
plugins/marketplaces/
plugins/installed_plugins.json
plugins/known_marketplaces.json
