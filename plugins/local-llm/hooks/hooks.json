{
  "description": "local-llm lifecycle hooks — dependency installation, health check, delegation instruction injection",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/session-start/ss.llm.deps.js" },
          { "type": "command", "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/session-start/ss.llm.health.js" }
        ]
      }
    ]
  }
}
