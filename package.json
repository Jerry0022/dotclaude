{
  "name": "@Jerry0022/dotclaude",
  "version": "0.37.1",
  "description": "Global Claude Code configuration — instructions, hooks, skills, and scripts",
  "author": "Jerry0022",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jerry0022/dotclaude.git"
  },
  "bin": {
    "dotclaude": "bin/cli.js"
  },
  "files": [
    "bin/",
    "CLAUDE.md",
    "commands/",
    "skills/",
    "scripts/*.js",
    "scripts/package.json",
    "scripts/diagrams/template.html",
    "plugins/",
    "templates/"
  ],
  "scripts": {
    "setup": "node bin/cli.js setup",
    "setup:bash": "bash setup.sh",
    "setup:win": "powershell -ExecutionPolicy Bypass -File setup.ps1"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "pkg": {
    "assets": [
      "CLAUDE.md",
      "commands/**/*",
      "skills/**/*",
      "scripts/*.js",
      "scripts/package.json",
      "scripts/diagrams/template.html",
      "plugins/**/*",
      "templates/**/*"
    ],
    "outputPath": "dist"
  }
}
